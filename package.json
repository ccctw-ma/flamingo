{
  "name": "flamingo",
  "version": "1.0.0",
  "description": "Chrome extension for editing and applying Declarative Net Request proxy rules",
  "type": "module",
  "packageManager": "bun@1.3.10",
  "scripts": {
    "dev": "bun --watch scripts/build.ts",
    "build": "bun run typecheck && bun scripts/build.ts",
    "typecheck": "bun x tsc --noEmit",
    "lint": "bun x eslint .",
    "lint:fix": "bun x eslint . --fix",
    "format": "bun x prettier --write .",
    "test": "bun test tests/*.test.ts",
    "test:e2e": "bun x playwright test",
    "check": "bun run typecheck && bun run lint && bun run test && bun run test:e2e"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@playwright/test": "^1.60.0",
    "@types/bun": "^1.3.3",
    "@types/chrome": "^0.0.241",
    "@types/node": "^20.10.4",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "autoprefixer": "^10.4.16",
    "eslint": "^9.16.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.13.0",
    "husky": "^8.0.3",
    "postcss": "^8.4.32",
    "prettier": "^3.1.1",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.18.0"
  },
  "dependencies": {
    "@ant-design/cssinjs": "^1.18.1",
    "@ant-design/icons": "^5.2.6",
    "antd": "^5.12.1",
    "@monaco-editor/react": "^4.6.0",
    "monaco-editor": "^0.44.0",
    "zustand": "^4.4.7"
  }
}
