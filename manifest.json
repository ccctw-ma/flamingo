{
    "manifest_version": 3,
    "name": "flamingo",
    "version": "1.0.0",
    "description": "chrome extension for proxy",
    "icons": {
        "16": "images/flamingo_16.png",
        "32": "images/flamingo_32.png",
        "48": "images/flamingo_48.png",
        "128": "images/flamingo_128.png"
    },
    "action": {
        "default_icon": {
            "16": "images/flamingo_16.png",
            "32": "images/flamingo_32.png",
            "48": "images/flamingo_48.png"
        },
        "default_title": "Hello Flamingo",
        "default_popup": "home.html"
    },
    "permissions": [
        "storage",
        "tabs",
        "declarativeNetRequest",
        "declarativeNetRequestWithHostAccess",
        "declarativeNetRequestFeedback"
    ],
    "host_permissions": [
        "https://*/*",
        "http://*/*"
    ],
    "background": {
        "service_worker": "src/background.js",
        "type": "module"
    }
}
