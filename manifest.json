{
  "manifest_version": 3,
  "name": "Flamingo",
  "version": "1.0.0",
  "description": "Create local Chrome Declarative Net Request rules to redirect, block, or modify request and response headers.",
  "icons": {
    "16": "images/flamingo_16.png",
    "32": "images/flamingo_32.png",
    "48": "images/flamingo_48.png",
    "128": "images/flamingo_128.png"
  },
  "action": {
    "default_icon": {
      "16": "images/flamingo_grey_16.png",
      "32": "images/flamingo_grey_32.png",
      "48": "images/flamingo_grey_48.png"
    },
    "default_title": "Flamingo",
    "default_popup": "home.html"
  },
  "permissions": [
    "storage",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess",
    "webRequest",
    "webRequestBlocking"
  ],
  "host_permissions": ["https://*/*", "http://*/*"],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["src/mockMain.js"],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    },
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["src/contentBridge.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ]
}
